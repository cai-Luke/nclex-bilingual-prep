{
  "name": "nclex-bilingual-prep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && tsx scripts/make-file-build.ts",
    "preview": "vite preview --host 0.0.0.0",
    "coverage-report": "tsx scripts/coverage-report.ts",
    "test-visuals": "tsx scripts/tests/rhythm-strip.ts && tsx scripts/tests/capnography.ts && tsx scripts/tests/visuals-conformance.ts && tsx scripts/tests/registry-mechanics.ts && tsx scripts/tests/visual-parity.ts",
    "validate-bank": "tsx scripts/validate-bank.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^0.468.0",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2"
  }
}
